{
  "expo": {
    "name": "Flowy",
    "slug": "flowy",
    "scheme": "flowy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.flowy.app",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.flowy.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "fb0632a7-fa04-4f67-8030-05c69796af84"
      }
    },
    "owner": "gagnonthomas",
    "plugins": [
      "expo-router",
      "expo-font",
"@react-native-community/datetimepicker"
    ]
  }
}
